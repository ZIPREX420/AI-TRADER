# solalpha env vars (copy to .env and fill in). The .env file is gitignored.
# All vars are optional unless marked REQUIRED. Defaults come from config/default.yaml.
# Env vars override YAML values. Nested fields use double underscore: SOLALPHA_RPC__POOL__0__URL=...

# ---- Profile selection ----
# Picks which YAML in config/ to load. Defaults to "default".
SOLALPHA_PROFILE=paper

# ---- Live trading hard switch ----
# Live execution is REFUSED unless this is set to 1. The legacy alias
# SOLANA_LIVE_TRADING=1 is also accepted.
SOLALPHA_LIVE_TRADING=0

# ---- Wallet / signer (only required for LIVE mode) ----
# Path to a Solana keypair JSON file (the array-of-bytes format produced by
# `solana-keygen new -o keypair.json`). Keep mode 600. NEVER commit.
SOLALPHA_KEYPAIR_PATH=

# ---- RPC endpoints (at least 2 recommended) ----
# Comma-separated. WS URLs auto-derived if URL starts with https://.
# Example: SOLALPHA_RPC_URLS=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY,https://api.mainnet-beta.solana.com
SOLALPHA_RPC_URLS=

# Optional comma-separated WS overrides (otherwise derived from HTTP URLs).
SOLALPHA_RPC_WS_URLS=

# ---- Jupiter ----
# Defaults to public Jupiter v6. Override for self-hosted.
SOLALPHA_JUPITER_BASE_URL=https://quote-api.jup.ag/v6

# ---- Logging ----
# debug | info | warning | error
SOLALPHA_LOG_LEVEL=info
# json | console
SOLALPHA_LOG_FORMAT=json

# ---- Persistence ----
SOLALPHA_DATA_DIR=./data
SOLALPHA_LOG_DIR=./logs

# ---- Metrics ----
# Set to "" to disable Prometheus HTTP server.
SOLALPHA_METRICS_HOST=127.0.0.1
SOLALPHA_METRICS_PORT=9464

# ---- Research / nightly ----
# Optional S3-compatible store for nightly research data.
SOLALPHA_RESEARCH_DATA_URL=
SOLALPHA_RESEARCH_DATA_KEY=
SOLALPHA_RESEARCH_DATA_SECRET=

# ---- Test-only (do not set in production) ----
# Allow `pytest -m live --run-live` to actually hit RPCs.
SOLALPHA_TEST_LIVE=0
